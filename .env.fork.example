# Template for the fork-local docker-compose .env file.
#
# Usage:
#   1. Copy this file to .env (which is gitignored).
#   2. Fill in the values you actually use. Leave the rest blank or delete
#      them — Compose passes empty strings as empty env vars, which is
#      harmless for skills that gracefully no-op without their key.
#   3. Run `docker compose up -d`.
#
# See fork/NOTE-1-install.md for the walkthrough and fork/NOTE-3-discord.md
# for what each Discord variable is consumed by.

# -----------------------------------------------------------------------------
# Discord
# -----------------------------------------------------------------------------
# Empty DISCORD_ALLOWED_USERS means "allow all users" (Hermes treats an
# empty per-platform allowlist as no restriction). For a global open
# gateway, set GATEWAY_ALLOW_ALL_USERS=true below instead.
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
DISCORD_HOME_CHANNEL=
DISCORD_REQUIRE_MENTION=true
# Comma-separated channel IDs where the bot replies without @mention.
DISCORD_FREE_RESPONSE_CHANNELS=
# Set false to keep replies in the same channel instead of spawning a thread per message.
DISCORD_AUTO_THREAD=false

# Set true to bypass per-platform allowlists (Hermes denies all by default when allowlists are empty).
GATEWAY_ALLOW_ALL_USERS=true

# -----------------------------------------------------------------------------
# Blockchain / on-chain data
# -----------------------------------------------------------------------------
BLOCKSCOUT_API_KEY=
ALCHEMY_API_KEY=
CRYPTOPANIC_API_KEY=

# -----------------------------------------------------------------------------
# Gmail OAuth client identity. The refresh token is NOT stored here;
# Hermes' Google Workspace skill writes it into google_token.json in the
# local credential store after the first OAuth authorization.
# -----------------------------------------------------------------------------
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# OSINT / threat-intel
# -----------------------------------------------------------------------------
HUNTER_API_KEY=
ABSTRACT_API_KEY=
EMAILREP_API_KEY=
NUMVERIFY_API_KEY=
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=
OTX_API_KEY=
ABUSEIPDB_API_KEY=
CENSYS_API_KEY=
IPQS_API_KEY=
DEHASHED_API_KEY=
BREACHDIRECTORY_VIA_RAPIDAPI_API_KEY=

# -----------------------------------------------------------------------------
# Local services (reachable from inside the container)
# -----------------------------------------------------------------------------
# host.docker.internal resolves to the Docker host. Works on Docker Desktop
# (Windows/Mac) out of the box. On native Linux, the override file already
# adds extra_hosts so this still resolves.
ASCEND_SCRAPPER_URL=http://host.docker.internal:7021/api/v2/web/read

# -----------------------------------------------------------------------------
# Container UID/GID. Set to your host user so files in ~/.hermes stay
# readable on the host. On Linux: HERMES_UID=$(id -u). On Windows/WSL the
# defaults below are usually fine.
# -----------------------------------------------------------------------------
HERMES_UID=10000
HERMES_GID=10000

# -----------------------------------------------------------------------------
# Dashboard access (no reverse proxy)
# -----------------------------------------------------------------------------
# The dashboard is published to 127.0.0.1:9119 only — not reachable from the
# LAN. Local: http://localhost:9119. Remote: SSH tunnel from your laptop:
#   ssh -L 9119:localhost:9119 user@host
# then open http://localhost:9119 in your local browser.

# -----------------------------------------------------------------------------
# Optional LLM provider keys. Only needed if you go the API-key route
# instead of OAuth (MiniMax OAuth and Anthropic OAuth do not need keys).
# Uncomment and add the matching env passthrough line in
# docker-compose.override.yml under gateway.environment if you use these.
# -----------------------------------------------------------------------------
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OPENAI_API_KEY=
